type Department {
    id: ID
    name: String!
    duties: String!
    workers: [Worker!]
    projects: [Project!]

    workerCount: Int!
    projectCount: Int!
    averageImportance: Float!
}

input DepartmentCreateInput {
    name: String!
    duties: String!
}

input DepartmentUpdateInput {
    id: ID!
    name: String
    duties: String
}